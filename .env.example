# Django Configuration
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=127.0.0.1,localhost,.onrender.com
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://bincom-election-explorer.onrender.com

# Database (SQLite - local development)
# For production on Render, SQLite is fine; can migrate to PostgreSQL later
DATABASE_URL=sqlite:///db.sqlite3

# Optional: Sentry error tracking (uncomment to enable)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Optional: Analytics/tracking (uncomment to enable)
# GOOGLE_ANALYTICS_ID=UA-xxxxxxxx-x
